{
  "expo": {
    "name": "AgroElevate",
    "slug": "agroelevate-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "agroelevate",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.agronex.farmconnect",
      "infoPlist": {
        "NSCameraUsageDescription": "Take photos of your crops",
        "NSPhotoLibraryUsageDescription": "Choose crop images from gallery",
        "NSLocationWhenInUseUsageDescription": "Show nearby farmers"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#16a34a"
      },
      "package": "com.agronex.farmconnect",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.RECORD_AUDIO"
      ],
      "edgeToEdgeEnabled": true
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#16a34a"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Choose crop images from your gallery"
        }
      ],
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "backendUrl": "http://10.0.2.2:8001",
      "router": {},
      "eas": {
        "projectId": "5568e8e7-6cc1-4691-bb74-f2d4c09017a7"
      }
    }
  }
}
